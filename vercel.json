{
  "version": 2,
  "framework": "create-react-app",
  "buildCommand": "npm run build:client",
  "outputDirectory": "client/build",
  "routes": [
    {
      "src": "/api$",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...route].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}